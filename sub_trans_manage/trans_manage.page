			<script>
			$('.category_change').on('click', function(){
				if ($('#table_flag').val() != '1')
				{
					$('.table_change').css('opacity', '0');
					$('.table_change').css('display', 'none');
					$('.category_change').css('opacity', '0.9');
					$('.category_change').css('background-color', '#aeaeae');
					$('#table_flag').val('1');
				}
				if ($(this).css('opacity') != '1')
				{
					$('.table_change').css('opacity', '0');
					$('.table_change').css('display', 'none');
					$('.category_change').css('opacity', '0.9');
					$('.category_change').css('background-color', '#aeaeae');
					$('.'+$(this).data('classname')).css('opacity', '1');
					$('.'+$(this).data('classname')).css('display', 'table-cell');
					$(this).css('opacity', '1');
					$(this).css('background-color', '#85b6ff');
				}
				else
				{
					$('.table_change').css('opacity', '1');
					$('.table_change').css('display', 'table-cell');
					$('.category_change').css('opacity', '1');
					$('.category_change').css('background-color', '#85b6ff');
					$('#table_flag').val('0');
				}
			});
			function category_all(){
				$('.table_change').css('opacity', '1');
				$('.table_change').css('display', 'table-cell');
				$('.category_change').css('opacity', '1');
				$('.category_change').css('background-color', '#85b6ff');
				$('#opacity_flag').val('0');
			}
